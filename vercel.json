{
  "functions": {
    "api/[...route].js": {
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/telegram-report/send",
      "schedule": "30 2 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...route]" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
